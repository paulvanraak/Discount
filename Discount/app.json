{
  "expo": {
    "name": "Donnie Discount",
    "slug": "donnie-discount",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF4040"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.donniediscount.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF8C00"
      },
      "package": "com.donniediscount.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/icon.png",
      "name": "Donnie Discount",
      "shortName": "Donnie",
      "description": "Extreme kortingen. Elke dag.",
      "themeColor": "#FF4040",
      "backgroundColor": "#FF4040"
    },
    "plugins": [],
    "assetBundlePatterns": [
      "**/*"
    ]
  }
}
